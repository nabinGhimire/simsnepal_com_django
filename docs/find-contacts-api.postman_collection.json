          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"contacts\": [\"contact@example.com\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/contacts/find",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "contacts", "find"]
        },
        "description": "Test validation error when sending >100 contacts"
      }
    },
    {
      "name": "Find Contacts - No Auth (401)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Returns 401 without auth', function() {",
              "    pm.response.to.have.status(401);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"contacts\": [\"test@example.com\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/contacts/find",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "contacts", "find"]
        },
        "description": "Test unauthorized request (no token)"
      }
    }
  ]
}